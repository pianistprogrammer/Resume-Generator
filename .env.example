# ============================================
# JobAlert AI - Environment Variables Reference
# ============================================
# NOTE: A real .env file already exists with a secure SECRET_KEY
# This is just a reference for available variables
# ============================================

# Application
APP_NAME=JobAlert AI
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# Admin Credentials
ADMIN_EMAIL=admin@jobalert.ai
ADMIN_PASSWORD=change-this-secure-password

# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=jobalert

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# LLM Provider Configuration
LLM_PROVIDER=anthropic  # Options: anthropic, openai, openrouter, lmstudio, ollama

# OpenAI
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096

# OpenRouter
OPENROUTER_API_KEY=sk-or-xxxxx
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_MAX_TOKENS=4096

# LMStudio (local)
# Two API styles supported:
# 1. Anthropic-compatible (recommended): http://localhost:1234/v1
# 2. Custom /chat endpoint: http://localhost:1234/api/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=gpt-oss-20b-mlx
LMSTUDIO_MAX_TOKENS=4096

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_MAX_TOKENS=4096

# SendGrid
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=noreply@jobalert.ai
SENDGRID_FROM_NAME=JobAlert AI

# Stripe
STRIPE_API_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_SINGLE=price_xxxxx
STRIPE_PRICE_5PACK=price_xxxxx
STRIPE_PRICE_UNLIMITED=price_xxxxx

# Cloudflare R2
R2_ENDPOINT_URL=https://xxxxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx
R2_BUCKET_NAME=jobalert-resumes
R2_PUBLIC_URL=https://cdn.jobalert.ai

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Features
FREE_CREDITS=3
MIN_MATCH_SCORE=60.0
DIGEST_HOUR=18
FEED_REFRESH_MINUTES=30
MAX_JOBS_PER_FEED=100
